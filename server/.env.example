# Mercado Pago — https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
# Deixe vazio para modo mock (PIX simulado, útil em dev)
MP_MOCK=true

# PostgreSQL (Render, local, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opala_coins
# Render/Heroku managed Postgres: DATABASE_SSL=true
DATABASE_SSL=false

# Estoque inicial de coins para venda (ajuste no admin depois)
DEFAULT_STOCK_COINS=0

# Admin — senha do painel /admin
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-long-random-string

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://antoniohenriqueac.github.io,https://opala-wiki-1.onrender.com

# In-game char que recebe coins no fluxo de venda
GAME_RECEIVER_CHAR=SeuChar

# Notificações (opcional)
DISCORD_WEBHOOK_URL=

# URL pública da API (para webhook MP)
PUBLIC_API_URL=http://localhost:3001
